---
import "../styles/global.css";
import { getCollection } from "astro:content";
import { detailUrl, type Locale, type ContentMeta } from "@expertcont/i18n";
import { site } from "../site";

interface Props {
  title: string;
  description?: string;
  locale: Locale;
  /** Path for canonical (relative, e.g. "/servicii/contabilitate"). */
  path: string;
  /** Sibling URLs per locale for hreflang alternates. If omitted, uses path for all. */
  siblings?: Record<Locale, string>;
  /** Per-page structured data (object or array). Rendered after sitewide Organization. */
  jsonLd?: object | object[];
  /** Open Graph type. Defaults to "website"; pass "article" for blog/guide posts. */
  ogType?: "website" | "article";
  /** Article publish timestamp (ISO 8601) — only used when ogType === "article". */
  publishedTime?: string;
  /** Article last-modified timestamp (ISO 8601) — only used when ogType === "article". */
  modifiedTime?: string;
  /** Article author display name — only used when ogType === "article". */
  author?: string;
  /**
   * Include the AccountingService.hasOfferCatalog block (all 6 services nested) in
   * the sitewide Organization schema. Adds ~2KB of JSON-LD per page, so we opt in
   * only on pages where the full catalog is contextually relevant (home, services
   * index, about). All other pages still get the Organization entity — just
   * without the catalog. Defaults to false.
   */
  includeOfferCatalog?: boolean;
}

const {
  title,
  description,
  locale,
  path,
  siblings,
  jsonLd,
  ogType = "website",
  publishedTime,
  modifiedTime,
  author,
  includeOfferCatalog = false,
} = Astro.props;
const siteUrl = import.meta.env.PUBLIC_SITE_URL ?? "https://expertcont.md";
const canonical = `${siteUrl}${path}`;

const gtmId = import.meta.env.PUBLIC_GTM_ID as string | undefined;
const gscVerify = import.meta.env.PUBLIC_GSC_VERIFY as string | undefined;
const bingVerify = import.meta.env.PUBLIC_BING_VERIFY as string | undefined;
const alts: Record<Locale, string> = siblings ?? { ro: path, ru: path, en: path };
const langAttr = locale === "ro" ? "ro" : locale === "ru" ? "ru" : "en";
const ogLocaleByLocale: Record<Locale, string> = {
  ro: "ro_RO",
  ru: "ru_RU",
  en: "en_US",
};
const ogLocale = ogLocaleByLocale[locale];
const ogLocaleAlternates = (Object.keys(ogLocaleByLocale) as Locale[])
  .filter((l) => l !== locale)
  .map((l) => ogLocaleByLocale[l]);
const ogImage = `${siteUrl}/og.png`;
const ogImageAlt = title;

// Build a Service catalog from the services-meta collection so the schema
// reflects the actual offering. Locale-aware URLs are derived via detailUrl.
// Only built/serialized when the page opts in via includeOfferCatalog, to
// avoid shipping ~2KB of nested JSON-LD on every page.
const hasOfferCatalog = includeOfferCatalog
  ? {
      "@type": "OfferCatalog",
      name: "Servicii ExpertCont",
      itemListElement: (await getCollection("services-meta")).map((e) => {
        const s = e.data as ContentMeta;
        return {
          "@type": "Offer",
          itemOffered: {
            "@type": "Service",
            name: s.titles[locale],
            description: s.summaries[locale],
            url: `${siteUrl}${detailUrl("services", s, locale)}`,
          },
        };
      }),
    }
  : null;

// sameAs links non-empty social profiles to the business entity (Knowledge
// Panel signal). Empty strings in site.yml are filtered out.
const sameAs = [
  site.business.socials.facebook,
  site.business.socials.linkedin,
  site.business.socials.instagram,
].filter((u) => u.length > 0);

// AccountingService is a schema.org subtype of LocalBusiness — eligible for
// local-pack and rich results. Pricing tier "$$" maps to the Start package
// (2499 MDL/mo). Opening hours mirror site.business.hours (Mon–Fri 9–18).
const organizationJsonLd = {
  "@context": "https://schema.org",
  "@type": "AccountingService",
  name: site.business.name,
  slogan: site.business.slogan,
  foundingDate: site.business.foundingDate,
  numberOfEmployees: {
    "@type": "QuantitativeValue",
    minValue: site.business.employees.min,
    maxValue: site.business.employees.max,
  },
  url: siteUrl,
  logo: `${siteUrl}/logos/logo-vertical.png`,
  image: `${siteUrl}/og.png`,
  description:
    "Servicii de contabilitate, evidență contabilă, consultanță juridică și HR pentru companii din Republica Moldova.",
  priceRange: "$$",
  address: {
    "@type": "PostalAddress",
    streetAddress: site.business.address.street.ro,
    addressLocality: site.business.address.city.ro,
    addressCountry: site.business.address.countryCode,
    postalCode: site.business.address.postalCode,
  },
  telephone: site.business.phone,
  email: site.business.email,
  contactPoint: {
    "@type": "ContactPoint",
    telephone: site.business.phone,
    email: site.business.email,
    contactType: "customer service",
    availableLanguage: ["Romanian", "Russian", "English"],
    areaServed: site.business.address.countryCode,
  },
  areaServed: {
    "@type": "Country",
    name: site.business.address.countryName.ro,
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: 47.02536313902645,
    longitude: 28.83902617001159,
  },
  openingHoursSpecification: {
    "@type": "OpeningHoursSpecification",
    dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
    opens: "09:00",
    closes: "18:00",
  },
  ...(hasOfferCatalog && { hasOfferCatalog }),
  ...(sameAs.length > 0 && { sameAs }),
};
---

<!doctype html>
<html lang={langAttr}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#4663ab" />

    {gscVerify && <meta name="google-site-verification" content={gscVerify} />}
    {bingVerify && <meta name="msvalidate.01" content={bingVerify} />}

    {
      /* Consent Mode v2 default + gtag() bootstrap. Must run before GTM so
        any tag loaded by GTM sees a consent state. We default to denied for
        marketing storage; the cookie banner upgrades on accept. Returning
        users who previously accepted get an immediate inline upgrade so we
        don't lose a pageview waiting for React hydration. */
    }
    <script is:inline>
      (function () {
        window.dataLayer = window.dataLayer || [];
        function gtag() {
          window.dataLayer.push(arguments);
        }
        window.gtag = gtag;
        var granted = {
          ad_storage: "granted",
          ad_user_data: "granted",
          ad_personalization: "granted",
          analytics_storage: "granted",
        };
        var denied = {
          ad_storage: "denied",
          ad_user_data: "denied",
          ad_personalization: "denied",
          analytics_storage: "denied",
        };
        gtag("consent", "default", denied);
        try {
          if (window.localStorage.getItem("expertcont-cookie-consent") === "accepted") {
            gtag("consent", "update", granted);
          }
        } catch (e) {
          /* localStorage blocked — leave defaults */
        }

        // Track tel: link clicks via event delegation (covers all components).
        document.addEventListener(
          "click",
          function (e) {
            var t = e.target;
            if (!(t instanceof Element)) return;
            var a = t.closest('a[href^="tel:"]');
            if (!a) return;
            window.dataLayer.push({
              event: "phone_link_clicked",
              location: window.location.pathname || "/",
            });
          },
          { passive: true, capture: true },
        );
      })();
    </script>

    {
      gtmId && (
        <script is:inline define:vars={{ gtmId }}>{`
        (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
        new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
        j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
        'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer','${gtmId}');
      `}</script>
      )
    }

    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="16x16" href="/icons/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icons/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="96x96" href="/icons/favicon-96x96.png" />
    <link rel="icon" type="image/png" sizes="128x128" href="/icons/favicon-128x128.png" />
    <link rel="apple-touch-icon" sizes="128x128" href="/icons/favicon-128x128.png" />

    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="ro" href={`${siteUrl}${alts.ro}`} />
    <link rel="alternate" hreflang="ru" href={`${siteUrl}${alts.ru}`} />
    <link rel="alternate" hreflang="en" href={`${siteUrl}${alts.en}`} />
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}${alts.ro}`} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1640" />
    <meta property="og:image:height" content="856" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:locale" content={ogLocale} />
    {ogLocaleAlternates.map((l) => <meta property="og:locale:alternate" content={l} />)}
    <meta property="og:site_name" content="ExpertCont" />
    {
      ogType === "article" && publishedTime && (
        <meta property="article:published_time" content={publishedTime} />
      )
    }
    {
      ogType === "article" && modifiedTime && (
        <meta property="article:modified_time" content={modifiedTime} />
      )
    }
    {ogType === "article" && author && <meta property="article:author" content={author} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(organizationJsonLd)} />
    {
      jsonLd &&
        (Array.isArray(jsonLd) ? jsonLd : [jsonLd]).map((node) => (
          <script is:inline type="application/ld+json" set:html={JSON.stringify(node)} />
        ))
    }

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&display=swap"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    {
      gtmId && (
        <noscript>
          <iframe
            src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`}
            height="0"
            width="0"
            class="hidden"
            aria-hidden="true"
            title="gtm"
          />
        </noscript>
      )
    }
    <slot />
  </body>
</html>
