---
import type { GetStaticPaths } from "astro";
import Base from "../../layouts/Base.astro";
import PageShell from "../../components/PageShell.astro";
import { Container, PageHeader, Section } from "@expertcont/ui";
import { homeUrl, sectionUrl, type Locale } from "@expertcont/i18n";
import {
  INDUSTRIES,
  industryDetailUrl,
  industryDetailSiblings,
  type Industry,
} from "../../components/industry/industries";
import { serviceJsonLd, breadcrumbListJsonLd } from "../../lib/jsonLd";

export const getStaticPaths = (() =>
  INDUSTRIES.map((industry) => ({
    params: { slug: industry.slug },
    props: { industry },
  }))) satisfies GetStaticPaths;

const locale: Locale = "ro";
const { industry } = Astro.props as { industry: Industry };
const title = industry.title[locale];
const path = industryDetailUrl(industry.slug, locale);
const siblings = industryDetailSiblings(industry.slug);
const pricingHref = sectionUrl("pricing", locale);
const contactHref = sectionUrl("contact", locale);
const metaDescription = `Contabilitate specializată pentru ${title} în Moldova. Înțelegem realitățile fiscale ale domeniului tău — manager de cont dedicat și răspuns rapid.`;

const jsonLd = [
  serviceJsonLd({
    url: path,
    name: `Contabilitate pentru ${title}`,
    description: metaDescription,
    locale,
  }),
  breadcrumbListJsonLd([
    { name: "Acasă", url: homeUrl(locale) },
    { name: "Domenii", url: sectionUrl("industries", locale) },
    { name: title, url: path },
  ]),
];
---

<Base
  title={`Contabilitate pentru ${title} — ExpertCont`}
  description={metaDescription}
  locale={locale}
  path={path}
  siblings={siblings}
  jsonLd={jsonLd}
>
  <PageShell locale={locale} siblings={siblings}>
    <PageHeader
      eyebrow="Domeniu"
      title={`Contabilitate pentru ${title}`}
      breadcrumbs={[
        { label: "Acasă", href: homeUrl(locale) },
        { label: "Domenii", href: sectionUrl("industries", locale) },
        { label: title },
      ]}
    />

    <Section tone="default">
      <Container>
        <div class="mx-auto max-w-3xl">
          <p class="text-lg leading-relaxed text-text-secondary mb-10">
            {industry.description[locale]}
          </p>
          <div class="flex flex-wrap gap-4">
            <a href={pricingHref} class="btn btn-primary">Vezi prețuri</a>
            <a href={contactHref} class="btn btn-secondary">Programează o consultație</a>
          </div>
        </div>
      </Container>
    </Section>
  </PageShell>
</Base>
