---
import Base from "../layouts/Base.astro";
import PageShell from "../components/PageShell.astro";
import LegalIsland from "../components/legal/LegalIsland";
import { sectionUrl, type Locale } from "@expertcont/i18n";

const locale: Locale = "ro";
const kind = "terms" as const;
const path = sectionUrl("terms", locale);
const siblings: Record<Locale, string> = {
  ro: sectionUrl("terms", "ro"),
  ru: sectionUrl("terms", "ru"),
  en: sectionUrl("terms", "en"),
};
---

<Base
  title="Termeni și condiții — ExpertCont"
  description="Termenii și condițiile de utilizare a site-ului și serviciilor de contabilitate, juridice, HR și consultanță oferite de ExpertCont companiilor din Moldova."
  locale={locale}
  path={path}
  siblings={siblings}
>
  <PageShell locale={locale} siblings={siblings}>
    <LegalIsland
      client:visible
      locale={locale}
      kind={kind}
      contactHref={sectionUrl("contact", locale)}
    />
  </PageShell>
</Base>
