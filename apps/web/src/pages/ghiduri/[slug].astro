---
import type { GetStaticPaths } from "astro";
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";
import PageShell from "../../components/PageShell.astro";
import { Container, Section, ImagePlaceholder, SectionHeader } from "@expertcont/ui";
import { detailUrl, homeUrl, sectionUrl, type Locale } from "@expertcont/i18n";
import { guidesDetailProps, type GuideMeta } from "../../lib/guidesDetailProps";
import { articleJsonLd, breadcrumbListJsonLd } from "../../lib/jsonLd";

export const getStaticPaths = (async () => {
  const metas = await getCollection("guides-meta");
  return metas.map((m) => ({
    params: { slug: m.data.slugs.ro },
    props: { meta: m.data as GuideMeta },
  }));
}) satisfies GetStaticPaths;

const { meta } = Astro.props;
const locale: Locale = "ro";

const allGuides = await getCollection("guides");
const mdxEntry = allGuides.find((e) => e.data.contentId === meta.id && e.data.locale === "ro");
const { Content } = await render(mdxEntry!);

const siblings: Record<Locale, string> = {
  ro: detailUrl("guides", meta, "ro"),
  ru: detailUrl("guides", meta, "ru"),
  en: detailUrl("guides", meta, "en"),
};

const { labels, relatedGuides, relatedBlog, indexHref, contactHref } = await guidesDetailProps(
  meta,
  locale,
);
const category = meta.category[locale];
const guidePath = detailUrl("guides", meta, locale);
const jsonLd = [
  articleJsonLd({
    url: guidePath,
    title: meta.titles[locale],
    description: meta.summaries[locale],
    datePublished: meta.publishedAt ?? meta.updated,
    dateModified: meta.updated,
    locale,
    section: category,
  }),
  breadcrumbListJsonLd([
    { name: "Acasă", url: homeUrl(locale) },
    { name: "Ghiduri", url: sectionUrl("guides", locale) },
    { name: meta.titles[locale], url: guidePath },
  ]),
];
---

<Base
  title={`${meta.titles[locale]} — ExpertCont`}
  description={meta.summaries[locale]}
  locale={locale}
  path={guidePath}
  siblings={siblings}
  jsonLd={jsonLd}
>
  <PageShell locale={locale} activeSection="guides" siblings={siblings}>
    <Section tone="default" spacing="tight">
      <Container>
        <a
          href={indexHref}
          class="mb-6 inline-flex items-center gap-2 text-sm text-text-secondary no-underline"
        >
          {labels.backToAll}
        </a>
        <div class="mb-5 flex gap-2">
          <span class="pill">{category}</span>
        </div>
        <h1 class="mb-6 max-w-3xl text-[clamp(30px,4vw,48px)] leading-tight">
          {meta.titles[locale]}
        </h1>
        <div class="mb-8 flex items-center gap-4 text-sm text-text-secondary">
          <span>{meta.readTime} {labels.readTimeLabel}</span>
        </div>
        <ImagePlaceholder ratio="21/9" label="Guide cover" />
      </Container>
    </Section>

    <Section tone="default">
      <Container>
        <div class="grid grid-cols-1 gap-16 lg:grid-cols-[2fr_1fr]">
          <article class="text-lg leading-relaxed text-text-primary">
            <Content />
            <div class="mt-12 rounded-lg bg-primary p-8 text-white">
              <h3 class="mb-3 text-white">{labels.inlineCtaTitle}</h3>
              <p class="mb-5 text-white/80">{labels.inlineCtaSubtitle}</p>
              <a
                href={contactHref}
                class="btn btn-primary inline-flex items-center gap-2 no-underline"
              >
                {labels.inlineCtaButton}
              </a>
            </div>
          </article>

          <aside class="hidden flex-col gap-6 lg:flex">
            <div class="card sticky top-nav-h p-6">
              <div class="mb-4 text-xs font-bold uppercase tracking-widest text-text-secondary">
                {labels.tocLabel}
              </div>
              {
                [1, 2, 3].map((n) => (
                  <div
                    class:list={[
                      "flex items-center gap-3 py-2 text-sm",
                      n < 3 && "border-b border-border",
                    ]}
                  >
                    <span
                      class:list={[
                        "flex h-5 w-5 shrink-0 items-center justify-center rounded-full text-xs font-bold",
                        n === 1 ? "bg-primary text-white" : "bg-border text-text-secondary",
                      ]}
                    >
                      {n}
                    </span>
                    <span class="h-3 flex-1 rounded bg-border opacity-60" />
                  </div>
                ))
              }
            </div>

            <div class="card p-6">
              <div class="mb-3 text-xs font-bold uppercase tracking-widest text-text-secondary">
                {labels.similarLabel}
              </div>
              {relatedGuides.length > 0 ? (
                <div class="flex flex-col gap-3">
                  {
                    relatedGuides.map((p) => (
                      <a href={p.href} class="block no-underline">
                        <div class="card-flat p-4">
                          <span class="pill pill-soft mb-2 inline-block">{p.category}</span>
                          <div class="mt-1 mb-2 text-sm font-semibold leading-snug text-text-primary">
                            {p.title}
                          </div>
                          <div class="text-xs text-text-secondary">
                            {p.readTime} {labels.readTimeLabel}
                          </div>
                        </div>
                      </a>
                    ))
                  }
                </div>
              ) : (
                <p class="m-0 text-sm leading-relaxed text-text-secondary">
                  {labels.noRelatedFallback}
                </p>
              )}
            </div>
          </aside>
        </div>
      </Container>
    </Section>

    {relatedBlog.length > 0 && (
      <Section tone="alt">
        <Container>
          <SectionHeader
            eyebrow={labels.continueReadingEyebrow}
            title={labels.continueReadingTitle}
          />
          <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {
              relatedBlog.map((p) => (
                <article>
                  <a href={p.href} class="card card-hover block overflow-hidden p-0 no-underline">
                    <ImagePlaceholder ratio="16/10" label={p.category} />
                    <div class="p-6">
                      <span class="pill pill-soft mb-3 inline-block">{p.category}</span>
                      <h3 class="mt-2 mb-3 text-lg leading-snug text-text-primary">{p.title}</h3>
                      <div class="text-xs text-text-secondary">
                        {p.date} · {p.readTime} {labels.readTimeLabel}
                      </div>
                    </div>
                  </a>
                </article>
              ))
            }
          </div>
        </Container>
      </Section>
    )}
  </PageShell>
</Base>
