---
import type { GetStaticPaths } from "astro";
import Base from "../../../layouts/Base.astro";
import PageShell from "../../../components/PageShell.astro";
import { Container, Icon, PageHeader, Section } from "@expertcont/ui";
import {
  homeUrl,
  sectionUrl,
  serviceDetailUrl,
  type Locale,
  type ServiceId,
} from "@expertcont/i18n";
import {
  INDUSTRIES,
  industryDetailUrl,
  industryDetailSiblings,
  type Industry,
} from "../../../components/industry/industries";
import { serviceJsonLd, breadcrumbListJsonLd, faqPageJsonLd } from "../../../lib/jsonLd";

export const getStaticPaths = (() =>
  INDUSTRIES.map((industry) => ({
    params: { slug: industry.slug },
    props: { industry },
  }))) satisfies GetStaticPaths;

const locale: Locale = "ru";
const { industry } = Astro.props as { industry: Industry };
const detail = industry.detail?.[locale];
const title = industry.title[locale];
const path = industryDetailUrl(industry.slug, locale);
const siblings = industryDetailSiblings(industry.slug);
const pricingHref = sectionUrl("pricing", locale);
const contactHref = sectionUrl("contact", locale);
const metaDescription = `Специализированная бухгалтерия для отрасли «${title}» в Молдове. Понимаем налоговые реалии вашей сферы — персональный менеджер и быстрый ответ.`;

const serviceLabels: Record<ServiceId, string> = {
  accounting: "Бухгалтерия",
  audit: "Аудит",
  legal: "Юридические услуги",
  consulting: "Консалтинг",
  hr: "Расчёт зарплат и кадры",
  it: "IT-услуги",
};

/** Splits text on `**bold**` markers; odd segments are emphasized. */
function boldSegments(text: string): { text: string; bold: boolean }[] {
  return text.split(/\*\*(.+?)\*\*/g).map((seg, i) => ({ text: seg, bold: i % 2 === 1 }));
}

const jsonLd = [
  serviceJsonLd({
    url: path,
    name: `Бухгалтерия для отрасли «${title}»`,
    description: metaDescription,
    locale,
  }),
  breadcrumbListJsonLd([
    { name: "Главная", url: homeUrl(locale) },
    { name: "Отрасли", url: sectionUrl("industries", locale) },
    { name: title, url: path },
  ]),
  ...(detail ? [faqPageJsonLd(detail.faq)] : []),
];
---

<Base
  title={`Бухгалтерия для отрасли «${title}» — ExpertCont`}
  description={metaDescription}
  locale={locale}
  path={path}
  siblings={siblings}
  jsonLd={jsonLd}
>
  <PageShell locale={locale} siblings={siblings}>
    <PageHeader
      eyebrow="Отрасль"
      title={`Бухгалтерия для отрасли «${title}»`}
      breadcrumbs={[
        { label: "Главная", href: homeUrl(locale) },
        { label: "Отрасли", href: sectionUrl("industries", locale) },
        { label: title },
      ]}
    />

    {
      detail ? (
        <>
          <Section tone="default">
            <Container>
              <div class="mx-auto max-w-3xl">
                <p class="text-lg leading-relaxed mb-6">
                  {boldSegments(detail.intro).map((s) =>
                    s.bold ? <strong>{s.text}</strong> : s.text,
                  )}
                </p>
                {detail.overview && (
                  <p class="text-base leading-relaxed text-text-secondary mb-0">
                    {detail.overview}
                  </p>
                )}
              </div>
            </Container>
          </Section>

          <Section tone="alt" id="zadachi">
            <Container>
              <div class="mx-auto max-w-3xl">
                <h2 class="text-3xl mb-10">Какие задачи решаем</h2>
                <div class="flex flex-col gap-10">
                  {detail.challenges.map((c) => (
                    <article>
                      <h3 class="text-xl mb-3">{c.title}</h3>
                      <p class="text-text-secondary leading-relaxed mb-3">{c.problem}</p>
                      <p class="leading-relaxed mb-4">{c.solution}</p>
                      <a
                        href={serviceDetailUrl(c.service, locale)}
                        class="inline-flex items-center gap-1.5 text-sm font-semibold text-primary no-underline"
                      >
                        {serviceLabels[c.service]}
                        <Icon name="arrow-right" size={16} />
                      </a>
                    </article>
                  ))}
                </div>
              </div>
            </Container>
          </Section>

          <Section tone="default" id="faq">
            <Container>
              <div class="mx-auto max-w-3xl">
                <h2 class="text-3xl mb-10">Частые вопросы</h2>
                <div class="flex flex-col gap-6">
                  {detail.faq.map((f) => (
                    <div>
                      <h3 class="text-lg mb-2">{f.q}</h3>
                      <p class="text-text-secondary leading-relaxed mb-0">{f.a}</p>
                    </div>
                  ))}
                </div>
              </div>
            </Container>
          </Section>

          <Section tone="alt">
            <Container>
              <div class="mx-auto max-w-3xl text-center">
                <h2 class="text-2xl mb-4">Доверьте бухгалтерию тем, кто знает вашу отрасль</h2>
                <p class="text-text-secondary mb-8">
                  Начните с бесплатной консультации и персонального менеджера.
                </p>
                <div class="flex flex-wrap justify-center gap-4">
                  <a href={pricingHref} class="btn btn-primary">Смотреть цены</a>
                  <a href={contactHref} class="btn btn-secondary">Записаться на консультацию</a>
                </div>
              </div>
            </Container>
          </Section>
        </>
      ) : (
        <Section tone="default">
          <Container>
            <div class="mx-auto max-w-3xl">
              <p class="text-lg leading-relaxed text-text-secondary mb-10">
                {industry.description[locale]}
              </p>
              <div class="flex flex-wrap gap-4">
                <a href={pricingHref} class="btn btn-primary">Смотреть цены</a>
                <a href={contactHref} class="btn btn-secondary">Записаться на консультацию</a>
              </div>
            </div>
          </Container>
        </Section>
      )
    }
  </PageShell>
</Base>
