---
import Base from "../../layouts/Base.astro";
import PageShell from "../../components/PageShell.astro";
import FaqPageIsland from "../../components/faq/FaqPageIsland";
import { homeUrl, sectionUrl, type Locale } from "@expertcont/i18n";
import { faqPageJsonLd, breadcrumbListJsonLd } from "../../lib/jsonLd";
import { site } from "../../site";

const locale: Locale = "ru";
const siblings: Record<Locale, string> = {
  ro: sectionUrl("faq", "ro"),
  ru: sectionUrl("faq", "ru"),
  en: sectionUrl("faq", "en"),
};

const groups = [
  {
    cat: "Общие",
    items: [
      {
        q: "Работаете ли вы только с компаниями из Кишинёва?",
        a: "Нет, мы обслуживаем клиентов со всей Молдовы. С нашим онлайн-порталом всё сотрудничество может быть 100% дистанционным — от онбординга до ежемесячных отчётов.",
      },
      {
        q: "Каково среднее время ответа?",
        a: "Гарантируем ответ в течение 4 часов в рабочие дни. Для клиентов с пакетом Enterprise SLA составляет 2 часа.",
      },
      {
        q: "Какова минимальная продолжительность договора?",
        a: "Стандартно 12 месяцев, с возможностью расторжения с уведомлением за 30 дней после первых 3 месяцев.",
      },
    ],
  },
  {
    cat: "Бухгалтерия",
    items: [
      {
        q: "Какие бухгалтерские системы вы поддерживаете?",
        a: "1C, Universal Accounting, SmartAccount, Xero, Zoho Books. Мы можем перейти с текущей системы или внедрить новое решение.",
      },
      {
        q: "Как я получаю документы и отчёты?",
        a: "Через наш защищённый портал (доступ 24/7), по электронной почте и — по запросу — на ежемесячных встречах с менеджером по работе с клиентами.",
      },
      {
        q: "Есть ли у вас сертифицированные бухгалтеры?",
        a: "Все наши старшие бухгалтеры сертифицированы и являются членами Ассоциации бухгалтеров и аудиторов Молдовы (ACAP).",
      },
    ],
  },
  {
    cat: "Цены и договор",
    items: [
      {
        q: "Есть ли скрытые расходы?",
        a: "Нет. Всё, что указано в пакете, включено. Дополнительные услуги выставляются на счёт только по явному запросу, с предварительной котировкой.",
      },
      {
        q: "Как вы выставляете счета?",
        a: "Ежемесячно авансом, до 5-го числа. Банковский перевод или оплата картой.",
      },
      {
        q: "Могу ли я изменить пакет?",
        a: "Да, апгрейд или даунгрейд с уведомлением за 7 дней. Без штрафов.",
      },
    ],
  },
  {
    cat: "Техническое и онбординг",
    items: [
      {
        q: "Как работает портал документов?",
        a: "Наш защищённый портал позволяет загружать документы, просматривать отчёты и общаться с командой — доступен 24/7 с любого устройства.",
      },
      {
        q: "Сколько длится процесс онбординга?",
        a: "Обычно 5–7 рабочих дней: подписываем договор, назначаем менеджера по работе с клиентами, проводим установочную встречу и принимаем историю бухгалтерии.",
      },
    ],
  },
];

const jsonLd = [
  faqPageJsonLd(groups.flatMap((g) => g.items)),
  breadcrumbListJsonLd([
    { name: "Главная", url: homeUrl(locale) },
    { name: "Часто задаваемые вопросы", url: sectionUrl("faq", locale) },
  ]),
];
---

<Base
  title="Вопросы и ответы — ExpertCont"
  description="Ответы на наиболее распространённые вопросы об услугах бухгалтерии и консалтинга."
  locale={locale}
  path={sectionUrl("faq", locale)}
  siblings={siblings}
  jsonLd={jsonLd}
>
  <PageShell locale={locale} siblings={siblings}>
    <FaqPageIsland
      client:visible
      locale={locale}
      groups={groups}
      contactPhone={site.business.phone}
      contactEmail={site.business.email}
    />
  </PageShell>
</Base>
