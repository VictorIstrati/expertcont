---
import Base from "../../layouts/Base.astro";
import PageShell from "../../components/PageShell.astro";
import FaqPageIsland from "../../components/faq/FaqPageIsland";
import { homeUrl, sectionUrl, type Locale } from "@expertcont/i18n";
import { faqPageJsonLd, breadcrumbListJsonLd } from "../../lib/jsonLd";
import { site } from "../../site";

const locale: Locale = "ru";
const siblings: Record<Locale, string> = {
  ro: sectionUrl("faq", "ro"),
  ru: sectionUrl("faq", "ru"),
  en: sectionUrl("faq", "en"),
};

const groups = [
  {
    cat: "Общие",
    items: [
      {
        q: "Работаете ли вы только с компаниями из Кишинёва?",
        a: "Нет, мы обслуживаем клиентов со всей Молдовы. Всё сотрудничество может быть 100% дистанционным — общаемся по email, телефону и в чатах (WhatsApp, Viber, Telegram).",
      },
      {
        q: "Каково среднее время ответа?",
        a: "Гарантируем ответ в течение 4 часов в рабочие дни. Для клиентов с пакетом Premium приоритетный SLA составляет 2 часа.",
      },
      {
        q: "Какова минимальная продолжительность договора?",
        a: "Стандартно 12 месяцев, с возможностью расторжения с уведомлением за 30 дней после первых 3 месяцев.",
      },
      {
        q: "Работаете ли с клиентами из-за рубежа?",
        a: "Да, для нерезидентов, зарегистрировавших юридическое лицо в Республике Молдова (ООО, ICS, IT Park). Общаемся на румынском, русском или английском — язык выбираете на онбординге.",
      },
    ],
  },
  {
    cat: "Бухгалтерия",
    items: [
      {
        q: "Какое бухгалтерское ПО вы используете?",
        a: "Работаем исключительно на 1С — текущей версии для Республики Молдова. Для компаний с другими системами выполняем миграцию данных в 1С в рамках онбординга.",
      },
      {
        q: "Как я получаю документы и отчёты?",
        a: "По email, телефону или согласованным чат-каналам (WhatsApp, Viber, Telegram) — и по запросу на ежемесячных встречах с персональным менеджером.",
      },
      {
        q: "Какой опыт у ваших бухгалтеров?",
        a: "Наши старшие бухгалтеры имеют более 10 лет опыта в молдавской бухгалтерии и детально знают частые законодательные изменения. Команда в сумме — 15+ лет опыта в различных отраслях.",
      },
      {
        q: "Соответствуете ли требованиям IT Park?",
        a: "Да. Знаем налоговый режим IT Park (единый налог 7% на доход, освобождение от НДС на экспорт IT-услуг) и отдельную отчётность перед администрацией IT Park. Настраиваем 1С с адаптированным планом счетов.",
      },
      {
        q: "Как сменить текущего бухгалтера без срыва сроков?",
        a: "Наш онбординг спроектирован для перехода без пауз: принимаем историю учёта, проверяем начальные остатки и синхронизируемся с текущим календарём отчётности. Лучший период для перехода — 5–15 число месяца.",
      },
      {
        q: "Как вы защищаете финансовые данные компании?",
        a: "Документы передаются по зашифрованным каналам (email, WhatsApp Business, Telegram). Доступ к 1С ограничен на уровне персонального менеджера, с журналом аудита. Подписываем соглашение о конфиденциальности с каждым клиентом.",
      },
    ],
  },
  {
    cat: "Цены и договор",
    items: [
      {
        q: "Есть ли скрытые расходы?",
        a: "Нет. Всё, что указано в пакете, включено. Дополнительные услуги выставляются на счёт только по явному запросу, с предварительной котировкой.",
      },
      {
        q: "Как вы выставляете счета?",
        a: "Ежемесячно авансом, до 5-го числа. Оплата производится исключительно банковским переводом.",
      },
      {
        q: "Могу ли я изменить пакет?",
        a: "Да, апгрейд или даунгрейд с уведомлением за 7 дней. Без штрафов.",
      },
    ],
  },
  {
    cat: "Техническое и онбординг",
    items: [
      {
        q: "Как я отправляю документы и как мы общаемся?",
        a: "Документы отправляются по email или через чат (WhatsApp, Viber, Telegram). Текущее общение с менеджером — по email, телефону и в чатах. Канал выбираем на онбординге.",
      },
      {
        q: "Сколько длится процесс онбординга?",
        a: "Обычно 5–7 рабочих дней: подписываем договор, назначаем менеджера по работе с клиентами, проводим установочную встречу и принимаем историю бухгалтерии.",
      },
      {
        q: "Что если я потеряю оригинал документа?",
        a: "Для текущего учёта работаем и со сканами. Для обязательных оригиналов (налоговые накладные, первичные акты) помогаем получить дубликаты у эмитента или подготовить заявление о восстановлении по Налоговому кодексу.",
      },
      {
        q: "Оказываете ли сопровождение налоговых проверок?",
        a: "Да. Сопровождаем от получения уведомления о проверке до итогового ответа: подготовка досье, общение с инспектором, обжалование решений (при необходимости). В каждом пакете первый час сопровождения проверки включён.",
      },
    ],
  },
];

const jsonLd = [
  faqPageJsonLd(groups.flatMap((g) => g.items)),
  breadcrumbListJsonLd([
    { name: "Главная", url: homeUrl(locale) },
    { name: "Часто задаваемые вопросы", url: sectionUrl("faq", locale) },
  ]),
];
---

<Base
  title="Часто задаваемые вопросы о бухгалтерии — ExpertCont"
  description="Чёткие ответы на самые частые вопросы о бухгалтерских услугах, учёте, юридической консультации и HR для компаний в Молдове."
  locale={locale}
  path={sectionUrl("faq", locale)}
  siblings={siblings}
  jsonLd={jsonLd}
>
  <PageShell locale={locale} siblings={siblings}>
    <FaqPageIsland
      client:visible
      locale={locale}
      groups={groups}
      contactPhone={site.business.phone}
      contactEmail={site.business.email}
    />
  </PageShell>
</Base>
