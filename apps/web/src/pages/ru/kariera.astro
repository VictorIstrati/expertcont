---
import Base from "../../layouts/Base.astro";
import PageShell from "../../components/PageShell.astro";
import { CareersIsland } from "../../components/careers/CareersIsland";
import { sectionUrl, homeUrl, type Locale } from "@expertcont/i18n";

const locale: Locale = "ru";
const path = sectionUrl("careers", locale);
const siblings: Record<Locale, string> = {
  ro: sectionUrl("careers", "ro"),
  ru: sectionUrl("careers", "ru"),
  en: sectionUrl("careers", "en"),
};
---

<Base
  title="Карьера в ExpertCont — присоединяйтесь к команде в Кишинёве"
  description="Стройте карьеру в ExpertCont вместе с бухгалтерами, юристами, HR и IT-специалистами. Отправьте резюме — ответим, когда появится подходящая позиция."
  locale={locale}
  path={path}
  siblings={siblings}
>
  <PageShell locale={locale} siblings={siblings}>
    <CareersIsland client:visible locale={locale} homeHref={homeUrl(locale)} />
  </PageShell>
</Base>
