---
import Base from "../../layouts/Base.astro";
import PageShell from "../../components/PageShell.astro";
import SolutionsIsland from "../../components/solutions/SolutionsIsland";
import { sectionUrl, type Locale } from "@expertcont/i18n";

const locale: Locale = "ru";
const path = sectionUrl("solutions", locale);
const siblings: Record<Locale, string> = {
  ro: sectionUrl("solutions", "ro"),
  ru: sectionUrl("solutions", "ru"),
  en: sectionUrl("solutions", "en"),
};
---

<Base
  title="Бухгалтерские решения для каждого этапа бизнеса — ExpertCont"
  description="Бухгалтерские решения для стартапов, растущих ООО и зрелых компаний в Молдове. Адаптируем пакет и подход под этап вашего бизнеса — онбординг за 30 дней."
  locale={locale}
  path={path}
  siblings={siblings}
>
  <PageShell locale={locale} activeSection="solutions" siblings={siblings}>
    <SolutionsIsland
      client:visible
      locale={locale}
      bookHref={sectionUrl("contact", locale)}
      homeLabel="Главная"
      eyebrow="Решения для каждого этапа"
      pageTitle="Бухгалтерские решения под вашу ситуацию"
      pageSubtitle="Выберите отправную точку — и мы покажем, что именно сделаем для вашего бизнеса в первые 30 дней: от регистрации ООО до мультиюридических операций."
      breadcrumbSolutions="Решения"
      personaSwitchLabel="Выберите вашу ситуацию"
      deliverablesSectionLabel="В первые 30 дней мы выполним:"
      timelineLabel="Сроки"
      recommendedPackageLabel="Рекомендуемый пакет"
      fromLabel="от"
      otherSituationsLabel="Перейти к другим ситуациям"
      ctaTitle="Не узнаёте себя ни в одной?"
      ctaSubtitle="Позвоните нам на 5 минут. Вместе решим, подходим ли мы друг другу."
      bookLabel="Записаться на бесплатную консультацию"
      callLabel="Позвонить сейчас"
      personas={[
        {
          slug: "new-srl",
          short: "Хочу открыть ООО",
          headline: "Бухгалтерия для нового ООО",
          desc: "Вы собираетесь запустить бизнес и не хотите разбираться с бюрократией. Мы проведём вас с нуля — регистрация, первый банковский счёт, первая налоговая декларация.",
          tier: "Start",
          tierPrice: 2499,
          tierLabel: "MDL / месяц",
          time: "5–7 дней до запуска",
          deliverables: [
            "Регистрация ООО (с юридическим адресом и уставом)",
            "Настройка первичной бухгалтерии",
            "Помощь в открытии банковского счёта",
            "Первая налоговая декларация подаётся нами",
            "Вводная сессия — какие документы нужно хранить",
          ],
        },
        {
          slug: "startup",
          short: "Я стартап в первые 6 месяцев",
          headline: "Бухгалтерия для стартапа в первые 6 месяцев",
          desc: "Вы недавно запустили стартап и хотите сосредоточиться на продукте, а не на отчётности. Берём бухгалтерию со скидкой 50% на первые 6 месяцев — чтобы вы могли инвестировать разницу в рост.",
          tier: "Start",
          tierPrice: 2499,
          tierLabel: "MDL / месяц",
          salePct: 50,
          saleMonths: 6,
          saleSuffix: "мес",
          time: "Онбординг 3–5 дней",
          deliverables: [
            "Передача дел и синхронизация с вашей системой",
            "Настройка первичной бухгалтерии под стартап",
            "Налоговые и зарплатные декларации включены",
            "Налоговая консультация для инвесторов и раундов финансирования",
            "Персональный менеджер с первого дня",
          ],
        },
        {
          slug: "growing",
          short: "У меня 3–15 сотрудников и бухгалтер не отвечает",
          headline: "Бухгалтерия для растущего ООО — смена бухгалтера",
          desc: "У вас работающий бизнес, но бухгалтерия — источник стресса: запоздалые ответы, декларации в последний момент, нет рекомендаций. Мы берём на себя переход без потерь.",
          tier: "Standard",
          tierPrice: 2999,
          tierLabel: "MDL / месяц",
          time: "5–10 дней онбординга без пропущенных сроков",
          deliverables: [
            "Бесплатный аудит существующего учёта",
            "Приём документов и синхронизация систем",
            "Персональный менеджер аккаунта (ответ < 4ч)",
            "Налоговая оптимизация в первые 3 месяца",
            "Юридический доступ 2ч/месяц включён",
          ],
        },
        {
          slug: "enterprise",
          short: "Я CEO компании с 50+ сотрудниками",
          headline: "Бухгалтерия для компаний со сложными операциями",
          desc: "У вас мульти-объектные операции, консолидированная отчётность или требования МСФО. Вам нужна команда, а не один бухгалтер. Мы работаем с вашим CFO, а не заменяем его.",
          tier: "Enterprise",
          tierPrice: null,
          tierLabel: "Индивидуально",
          time: "Онбординг 3–4 недели, индивидуальный план",
          deliverables: [
            "Выделенная команда (2–4 человека)",
            "Консолидированная отчётность по нескольким юрлицам",
            "Соответствие МСФО / внутренний аудит",
            "SLA 2ч ответ, расширенная поддержка Пн–Пт",
            "Ежеквартально: стратегическая встреча с вашим CFO",
          ],
        },
      ]}
    />
  </PageShell>
</Base>
