---
import Base from "../../layouts/Base.astro";
import PageShell from "../../components/PageShell.astro";
import { PartnersIsland } from "../../components/partners/PartnersIsland";
import { sectionUrl, homeUrl, type Locale } from "@expertcont/i18n";

const locale: Locale = "ru";
const path = sectionUrl("partners", locale);
const siblings: Record<Locale, string> = {
  ro: sectionUrl("partners", "ro"),
  ru: sectionUrl("partners", "ru"),
  en: sectionUrl("partners", "en"),
};
---

<Base
  title="Партнёры — ExpertCont"
  description="Наша партнёрская сеть позволяет предлагать комплексные решения — от технологий и финансов до юридических и аудиторских услуг."
  locale={locale}
  path={path}
  siblings={siblings}
>
  <PageShell locale={locale} siblings={siblings}>
    <PartnersIsland client:load locale={locale} homeHref={homeUrl(locale)} />
  </PageShell>
</Base>
