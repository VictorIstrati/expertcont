---
import Base from "../../layouts/Base.astro";
import PageShell from "../../components/PageShell.astro";
import AboutIsland from "../../components/about/AboutIsland";
import { sectionUrl, type Locale } from "@expertcont/i18n";

const locale: Locale = "ru";

const path = sectionUrl("about", locale);
const siblings: Record<Locale, string> = {
  ro: sectionUrl("about", "ro"),
  ru: sectionUrl("about", "ru"),
  en: sectionUrl("about", "en"),
};
---

<Base
  title="О ExpertCont — бухгалтерская команда из Молдовы"
  description="ExpertCont — мультидисциплинарная команда бухгалтеров, юристов, HR и IT-консультантов, оказывающая интегрированные услуги компаниям в Молдове."
  locale={locale}
  path={path}
  siblings={siblings}
  includeOfferCatalog
>
  <PageShell locale={locale} activeSection="about" siblings={siblings}>
    <AboutIsland client:visible locale={locale} bookHref={sectionUrl("contact", locale)} />
  </PageShell>
</Base>
