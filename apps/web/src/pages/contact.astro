---
import Base from "../layouts/Base.astro";
import PageShell from "../components/PageShell.astro";
import { ContactIsland } from "../components/contact/ContactIsland";
import { sectionUrl, type Locale } from "@expertcont/i18n";
import { site, pick, addressFull } from "../site";

const locale: Locale = "ro";
const siblings: Record<Locale, string> = {
  ro: sectionUrl("contact", "ro"),
  ru: sectionUrl("contact", "ru"),
  en: sectionUrl("contact", "en"),
};
---

<Base
  title="Contact — ExpertCont"
  description="Contactați echipa ExpertCont pentru o consultație gratuită în contabilitate și fiscalitate."
  locale={locale}
  path={sectionUrl("contact", locale)}
  siblings={siblings}
>
  <PageShell locale={locale} activeSection="contact" siblings={siblings}>
    <ContactIsland
      client:visible
      locale={locale}
      address={addressFull(locale)}
      phone={site.business.phone}
      email={site.business.email}
      hours={pick(site.business.hours, locale)}
    />
  </PageShell>
</Base>
