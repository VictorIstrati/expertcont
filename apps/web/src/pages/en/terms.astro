---
import Base from "../../layouts/Base.astro";
import PageShell from "../../components/PageShell.astro";
import LegalIsland from "../../components/legal/LegalIsland";
import { sectionUrl, type Locale } from "@expertcont/i18n";

const locale: Locale = "en";
const kind = "terms" as const;
const path = sectionUrl("terms", locale);
const siblings: Record<Locale, string> = {
  ro: sectionUrl("terms", "ro"),
  ru: sectionUrl("terms", "ru"),
  en: sectionUrl("terms", "en"),
};
---

<Base
  title="Terms and Conditions — ExpertCont"
  description="Terms and conditions for using the ExpertCont website and our accounting, legal, HR, and consulting services for companies in Moldova."
  locale={locale}
  path={path}
  siblings={siblings}
>
  <PageShell locale={locale} siblings={siblings}>
    <LegalIsland
      client:visible
      locale={locale}
      kind={kind}
      contactHref={sectionUrl("contact", locale)}
    />
  </PageShell>
</Base>
