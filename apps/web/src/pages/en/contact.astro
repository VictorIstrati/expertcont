---
import Base from "../../layouts/Base.astro";
import PageShell from "../../components/PageShell.astro";
import { ContactIsland } from "../../components/contact/ContactIsland";
import { sectionUrl, type Locale } from "@expertcont/i18n";

const locale: Locale = "en";
const siblings: Record<Locale, string> = {
  ro: sectionUrl("contact", "ro"),
  ru: sectionUrl("contact", "ru"),
  en: sectionUrl("contact", "en"),
};
---

<Base
  title="Contact — ExpertCont"
  description="Contact the ExpertCont team for a free consultation on accounting and tax services."
  locale={locale}
  path={sectionUrl("contact", locale)}
  siblings={siblings}
>
  <PageShell locale={locale} activeSection="contact" siblings={siblings}>
    <ContactIsland
      client:only="react"
      locale={locale}
      address="Mitropolit Varlaam St. 65, Chișinău, MD-2012, Republic of Moldova"
      phone="+373 22 22 33 44"
      email="contact@expertcont.md"
      hours="Monday–Friday, 9:00–18:00"
    />
  </PageShell>
</Base>
