---
import Base from "../../layouts/Base.astro";
import PageShell from "../../components/PageShell.astro";
import AboutIsland from "../../components/about/AboutIsland";
import { sectionUrl, type Locale } from "@expertcont/i18n";

const locale: Locale = "en";

const path = sectionUrl("about", locale);
const siblings: Record<Locale, string> = {
  ro: sectionUrl("about", "ro"),
  ru: sectionUrl("about", "ru"),
  en: sectionUrl("about", "en"),
};
---

<Base
  title="About ExpertCont — accounting team in Moldova"
  description="ExpertCont — a multidisciplinary team of accountants, lawyers, HR and IT consultants delivering integrated services for companies in the Republic of Moldova."
  locale={locale}
  path={path}
  siblings={siblings}
  includeOfferCatalog
>
  <PageShell locale={locale} activeSection="about" siblings={siblings}>
    <AboutIsland client:visible locale={locale} bookHref={sectionUrl("contact", locale)} />
  </PageShell>
</Base>
