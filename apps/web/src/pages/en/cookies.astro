---
import Base from "../../layouts/Base.astro";
import PageShell from "../../components/PageShell.astro";
import LegalIsland from "../../components/legal/LegalIsland";
import { sectionUrl, type Locale } from "@expertcont/i18n";

const locale: Locale = "en";
const kind = "cookies" as const;
const path = sectionUrl("cookies", locale);
const siblings: Record<Locale, string> = {
  ro: sectionUrl("cookies", "ro"),
  ru: sectionUrl("cookies", "ru"),
  en: sectionUrl("cookies", "en"),
};
---

<Base
  title="Cookie Policy — ExpertCont"
  description="ExpertCont cookie policy: what cookies we use and how to manage them."
  locale={locale}
  path={path}
  siblings={siblings}
>
  <PageShell locale={locale} siblings={siblings}>
    <LegalIsland
      client:visible
      locale={locale}
      kind={kind}
      contactHref={sectionUrl("contact", locale)}
    />
  </PageShell>
</Base>
