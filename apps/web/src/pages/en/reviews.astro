---
import Base from "../../layouts/Base.astro";
import PageShell from "../../components/PageShell.astro";
import ReviewsPageIsland from "../../components/reviews/ReviewsPageIsland";
import { Container, PageHeader, Section } from "@expertcont/ui";
import { homeUrl, sectionUrl, type Locale } from "@expertcont/i18n";

const locale: Locale = "en";
const siblings: Record<Locale, string> = {
  ro: sectionUrl("reviews", "ro"),
  ru: sectionUrl("reviews", "ru"),
  en: sectionUrl("reviews", "en"),
};

const reviews = [
  {
    author: "Andrei Bostan",
    authorCompany: "LLC TechMD",
    rating: 5,
    body: "We have been working with ExpertCont for three years. The transition from our previous firm was seamless — no interruptions, no errors. The price is fair, communication is fast, and not a single deadline has been missed. I recommend them wholeheartedly to any IT company in Moldova.",
  },
  {
    author: "Maria Popescu",
    authorCompany: "LLC ContabilPro",
    rating: 5,
    body: "We turned to ExpertCont when our business grew rapidly and we needed a serious partner. Their team completely reorganised our bookkeeping in two weeks. Now we sleep soundly knowing everything is in order.",
  },
  {
    author: "Dmitri Vasiliev",
    authorCompany: "LLC LogisTrans",
    rating: 4,
    body: "Professional service and reasonable prices. I especially appreciate the advance notifications before every tax deadline. The risk of penalties has dropped significantly compared to before.",
  },
  {
    author: "Elena Țurcanu",
    authorCompany: "Sole trader Elena Țurcanu",
    rating: 5,
    body: "As a sole trader I needed someone to guide me step by step. ExpertCont helped me understand my tax obligations and optimise costs. The Basic plan is exactly what I needed — accessible and comprehensive.",
  },
  {
    author: "Ion Roibu",
    authorCompany: "LLC AgroMold",
    rating: 5,
    body: "We run an agricultural business with high seasonality and complex accounting. ExpertCont proved they understand the sector's specifics — subsidies, contracts with exporters, agricultural VAT. I recommend them to anyone in agribusiness.",
  },
  {
    author: "Vasile Munteanu",
    authorCompany: "LLC BuildExpert",
    rating: 4,
    body: "We have worked with ExpertCont for two years in the construction sector. They efficiently handle all the project documentation, CAS and monthly reports. Communication with the account manager is very prompt.",
  },
  {
    author: "Cristina Ungureanu",
    authorCompany: "LLC MedClinic",
    rating: 5,
    body: "The medical sector has specific tax requirements and ExpertCont knows all of them. We switched to them a year and a half ago and have no regrets. Professionalism and complete transparency.",
  },
  {
    author: "Sergiu Movilă",
    authorCompany: "LLC EventPro",
    rating: 5,
    body: "We organise events and our revenue is variable. ExpertCont helps us manage cash flow and always be prepared for tax obligations. The online portal is extremely convenient.",
  },
];
---

<Base
  title="Client reviews — what they say about ExpertCont services"
  description="Real client reviews of ExpertCont's accounting, legal consulting, HR and financial audit services in Moldova."
  locale={locale}
  path={sectionUrl("reviews", locale)}
  siblings={siblings}
>
  <PageShell locale={locale} siblings={siblings}>
    <PageHeader
      eyebrow="Reviews"
      title="What clients say"
      subtitle="Genuine reviews from clients who chose ExpertCont as their accounting and consulting partner."
      breadcrumbs={[{ label: "Home", href: homeUrl(locale) }, { label: "Reviews" }]}
    />
    <Section tone="default">
      <Container>
        <ReviewsPageIsland
          client:visible
          locale={locale}
          reviews={reviews}
          ratingSummaryLabel="from 247 reviews"
          filterChips={["All", "With photos", "5★ only", "Detailed only"]}
          ctaTitle="Leave a review"
          ctaBtn="Write a review"
          ctaNote="Only verified clients can leave reviews"
        />
      </Container>
    </Section>
  </PageShell>
</Base>
