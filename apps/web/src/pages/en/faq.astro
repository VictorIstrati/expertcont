---
import Base from "../../layouts/Base.astro";
import PageShell from "../../components/PageShell.astro";
import FaqPageIsland from "../../components/faq/FaqPageIsland";
import { homeUrl, sectionUrl, type Locale } from "@expertcont/i18n";
import { faqPageJsonLd, breadcrumbListJsonLd } from "../../lib/jsonLd";
import { site } from "../../site";

const locale: Locale = "en";
const siblings: Record<Locale, string> = {
  ro: sectionUrl("faq", "ro"),
  ru: sectionUrl("faq", "ru"),
  en: sectionUrl("faq", "en"),
};

const groups = [
  {
    cat: "General",
    items: [
      {
        q: "Do you work only with companies from Chișinău?",
        a: "No, we serve clients from all over Moldova. The entire collaboration can be 100% remote — we communicate by email, phone and chat (WhatsApp, Viber, Telegram).",
      },
      {
        q: "What is the average response time?",
        a: "We guarantee a response within 4 hours on business days. For Premium plan clients, the priority SLA is 2 hours.",
      },
      {
        q: "What is the minimum contract duration?",
        a: "Standard 12 months, with the option to terminate with 30-day notice after the first 3 months.",
      },
      {
        q: "Do you work with clients based outside Moldova?",
        a: "Yes, for non-resident founders who have registered an entity in the Republic of Moldova (LLC, ICS, IT Park). We communicate in Romanian, Russian or English — your choice at onboarding.",
      },
    ],
  },
  {
    cat: "Accounting",
    items: [
      {
        q: "Which accounting software do you use?",
        a: "We work exclusively on 1C — the current Republic of Moldova version. For companies coming from other systems, we handle the migration to 1C as part of onboarding.",
      },
      {
        q: "How do I receive documents and reports?",
        a: "By email, phone or your preferred chat channel (WhatsApp, Viber, Telegram) — and on request in monthly meetings with your dedicated account manager.",
      },
      {
        q: "What experience do your accountants have?",
        a: "Our senior accountants have over 10 years of experience in Moldovan accounting and know the frequent legislative changes in detail. The team has 15+ years of combined experience across many industries.",
      },
      {
        q: "Are you compatible with IT Park requirements?",
        a: "Yes. We know the IT Park tax regime (7% single tax on revenue, VAT exemption on exported IT services) and the separate reporting to the IT Park administration. We configure 1C with an adapted chart of accounts.",
      },
      {
        q: "How do I switch from my current accountant without missing deadlines?",
        a: "Our onboarding is designed for zero-pause transition: we take over the accounting history, verify opening balances, and sync with your current reporting calendar. The best window to switch is the 5th–15th of the month.",
      },
      {
        q: "How do you protect our financial data?",
        a: "Documents are transmitted via encrypted channels (email, WhatsApp Business, Telegram). 1C access is restricted at the account-manager level with audit logs. We sign a confidentiality agreement with every client.",
      },
    ],
  },
  {
    cat: "Pricing & Contract",
    items: [
      {
        q: "Are there any hidden costs?",
        a: "No. Everything listed in the package is included. Additional services are invoiced only on explicit request, with a quote provided in advance.",
      },
      {
        q: "How do you invoice?",
        a: "Monthly in advance, by the 5th of the month. Payment is exclusively by bank transfer.",
      },
      {
        q: "Can I change my plan?",
        a: "Yes, upgrade or downgrade with 7 days notice. No penalties.",
      },
    ],
  },
  {
    cat: "Technical & Onboarding",
    items: [
      {
        q: "How do I send documents and how do we communicate?",
        a: "Documents are sent by email or via chat (WhatsApp, Viber, Telegram). Ongoing communication with your account manager uses email, phone and chat — we pick the preferred channel at onboarding.",
      },
      {
        q: "How long does the onboarding process take?",
        a: "Usually 5–7 business days: we sign the contract, assign an account manager, hold an introductory meeting, and take over the accounting history.",
      },
      {
        q: "What happens if I lose an original document?",
        a: "Scans work for ongoing bookkeeping. For mandatory originals (tax invoices, primary documents), we help you obtain duplicates from the issuer or file a reconstitution request under the Tax Code.",
      },
      {
        q: "Do you support clients during tax inspections?",
        a: "Yes. We assist from the inspection notice through to the final response: dossier preparation, communication with the inspector, contesting decisions (if needed). All packages include the first hour of inspection support.",
      },
    ],
  },
];

const jsonLd = [
  faqPageJsonLd(groups.flatMap((g) => g.items)),
  breadcrumbListJsonLd([
    { name: "Home", url: homeUrl(locale) },
    { name: "FAQ", url: sectionUrl("faq", locale) },
  ]),
];
---

<Base
  title="Accounting FAQ — frequently asked questions · ExpertCont"
  description="Clear answers to the most common questions about accounting, bookkeeping, legal consulting and HR services for companies in Moldova."
  locale={locale}
  path={sectionUrl("faq", locale)}
  siblings={siblings}
  jsonLd={jsonLd}
>
  <PageShell locale={locale} siblings={siblings}>
    <FaqPageIsland
      client:visible
      locale={locale}
      groups={groups}
      contactPhone={site.business.phone}
      contactEmail={site.business.email}
    />
  </PageShell>
</Base>
