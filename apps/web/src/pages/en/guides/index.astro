---
import { getCollection } from "astro:content";
import Base from "../../../layouts/Base.astro";
import PageShell from "../../../components/PageShell.astro";
import GuidesIndexIsland from "../../../components/guides/GuidesIndexIsland";
import { sectionUrl, detailUrl, type Locale, type ContentMeta } from "@expertcont/i18n";
import { guidesIndexProps } from "../../../lib/guidesIndexProps";

const locale: Locale = "en";
const siblings: Record<Locale, string> = {
  ro: sectionUrl("guides", "ro"),
  ru: sectionUrl("guides", "ru"),
  en: sectionUrl("guides", "en"),
};

const props = await guidesIndexProps(locale);

const siteUrl = import.meta.env.PUBLIC_SITE_URL ?? "https://expertcont.md";
const guidesMetaEntries = await getCollection("guides-meta");
const guides: ContentMeta[] = guidesMetaEntries.map((e) => e.data as ContentMeta);
const guidesJsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: "ExpertCont practical guides",
    url: `${siteUrl}${sectionUrl("guides", locale)}`,
    inLanguage: "en",
    description:
      "Practical guides for entrepreneurs in the Republic of Moldova: company registration, VAT, taxation, employment law, and legal compliance.",
    mainEntity: {
      "@type": "ItemList",
      numberOfItems: guides.length,
      itemListElement: guides.map((m, i) => ({
        "@type": "ListItem",
        position: i + 1,
        item: {
          "@type": "Article",
          headline: m.titles[locale],
          description: m.summaries[locale],
          url: `${siteUrl}${detailUrl("guides", m, locale)}`,
        },
      })),
    },
  },
];
---

<Base
  title="ExpertCont practical guides — for entrepreneurs in Moldova"
  description="Step-by-step guides for entrepreneurs in the Republic of Moldova: LLC registration, VAT, taxation, employment law, and compliance with Moldovan legislation."
  locale={locale}
  path={sectionUrl("guides", locale)}
  siblings={siblings}
  jsonLd={guidesJsonLd}
>
  <PageShell locale={locale} activeSection="guides" siblings={siblings}>
    <GuidesIndexIsland client:visible {...props} />
  </PageShell>
</Base>
