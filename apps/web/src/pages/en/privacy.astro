---
import Base from "../../layouts/Base.astro";
import PageShell from "../../components/PageShell.astro";
import LegalIsland from "../../components/legal/LegalIsland";
import { sectionUrl, type Locale } from "@expertcont/i18n";

const locale: Locale = "en";
const kind = "privacy" as const;
const path = sectionUrl("privacy", locale);
const siblings: Record<Locale, string> = {
  ro: sectionUrl("privacy", "ro"),
  ru: sectionUrl("privacy", "ru"),
  en: sectionUrl("privacy", "en"),
};
---

<Base
  title="Privacy Policy — ExpertCont"
  description="How we collect, use, and protect ExpertCont clients' personal data, in line with Law 133/2011 of the Republic of Moldova on personal data protection."
  locale={locale}
  path={path}
  siblings={siblings}
>
  <PageShell locale={locale} siblings={siblings}>
    <LegalIsland
      client:visible
      locale={locale}
      kind={kind}
      contactHref={sectionUrl("contact", locale)}
    />
  </PageShell>
</Base>
