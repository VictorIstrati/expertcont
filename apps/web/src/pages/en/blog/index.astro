---
import Base from "../../../layouts/Base.astro";
import PageShell from "../../../components/PageShell.astro";
import BlogIndexIsland from "../../../components/blog/BlogIndexIsland";
import { sectionUrl, type Locale } from "@expertcont/i18n";
import { blogIndexProps } from "../../../lib/blogIndexProps";

const locale: Locale = "en";
const siblings: Record<Locale, string> = {
  ro: sectionUrl("blog", "ro"),
  ru: sectionUrl("blog", "ru"),
  en: sectionUrl("blog", "en"),
};

const props = await blogIndexProps(locale);
---

<Base
  title="Blog — ExpertCont"
  description="Articles on accounting, tax, and legislation for businesses in Moldova."
  locale={locale}
  path={sectionUrl("blog", locale)}
  siblings={siblings}
>
  <PageShell locale={locale} activeSection="blog" siblings={siblings}>
    <BlogIndexIsland client:visible {...props} />
  </PageShell>
</Base>
