---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import PageShell from "../../components/PageShell.astro";
import { Container, PageHeader, Section } from "@expertcont/ui";
import { homeUrl, sectionUrl, detailUrl, type Locale, type ContentMeta } from "@expertcont/i18n";
import { ServiceIndexGrid } from "../../components/service/ServiceIndexGrid";
import { ServiceCTAStrip } from "../../components/service/ServiceCTAStrip";
import ServicesComparison from "../../components/service/ServicesComparison.astro";

const locale: Locale = "ro";
const siblings: Record<Locale, string> = {
  ro: sectionUrl("services", "ro"),
  ru: sectionUrl("services", "ru"),
  en: sectionUrl("services", "en"),
};

const metaEntries = await getCollection("services-meta");
const services: ContentMeta[] = metaEntries.map((e) => e.data as ContentMeta);

const serviceItems = services.map((s) => ({
  meta: s,
  href: detailUrl("services", s, locale),
  scheduleHref: sectionUrl("contact", locale),
}));

const contactHref = sectionUrl("contact", locale);
---

<Base
  title="Servicii — ExpertCont"
  description="Servicii complete de contabilitate, audit financiar, juridice și consultanță de afaceri pentru companii din Republica Moldova."
  locale={locale}
  path={sectionUrl("services", locale)}
  siblings={siblings}
>
  <PageShell locale={locale} activeSection="services" siblings={siblings}>
    <PageHeader
      eyebrow="Servicii integrate"
      title="O singură echipă pentru toate nevoile afacerii tale"
      subtitle="De la contabilitate primară la consultanță strategică — acoperim toate domeniile-cheie pentru o afacere sănătoasă în Moldova."
      breadcrumbs={[{ label: "Acasă", href: homeUrl(locale) }, { label: "Servicii" }]}
    />

    <Section tone="default">
      <Container>
        <ServiceIndexGrid client:visible services={serviceItems} locale={locale} />
      </Container>
    </Section>

    <ServicesComparison locale={locale} />

    <Section tone="default">
      <Container>
        <ServiceCTAStrip client:visible locale={locale} contactHref={contactHref} />
      </Container>
    </Section>
  </PageShell>
</Base>
