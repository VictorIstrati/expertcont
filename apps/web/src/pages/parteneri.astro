---
import Base from "../layouts/Base.astro";
import PageShell from "../components/PageShell.astro";
import { PartnersIsland } from "../components/partners/PartnersIsland";
import { sectionUrl, homeUrl, type Locale } from "@expertcont/i18n";

const locale: Locale = "ro";
const path = sectionUrl("partners", locale);
const siblings: Record<Locale, string> = {
  ro: sectionUrl("partners", "ro"),
  ru: sectionUrl("partners", "ru"),
  en: sectionUrl("partners", "en"),
};
---

<Base
  title="Parteneri ExpertCont — rețea integrată pentru afaceri"
  description="Rețeaua noastră de parteneri tehnologici, financiari, juridici și de audit completează serviciile de contabilitate ExpertCont pentru afaceri din Moldova."
  locale={locale}
  path={path}
  siblings={siblings}
>
  <PageShell locale={locale} siblings={siblings}>
    <PartnersIsland client:visible locale={locale} homeHref={homeUrl(locale)} />
  </PageShell>
</Base>
