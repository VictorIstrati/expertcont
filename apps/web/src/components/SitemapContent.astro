---
import { Container, Section } from "@expertcont/ui";
import type { Locale } from "@expertcont/i18n";
import { buildSitemapGroups, sitemapPageMeta } from "../lib/sitemapData";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const groups = await buildSitemapGroups(locale);
const meta = sitemapPageMeta[locale];
---

<Section spacing="default">
  <Container>
    <p class="sitemap-lead">{meta.lead}</p>
    <div class="sitemap-grid">
      {
        groups.map((group) => (
          <section class="sitemap-group">
            <h2 class="sitemap-group__heading">{group.heading}</h2>
            <ul class="sitemap-list">
              {group.links.map((link) => (
                <li>
                  <a href={link.href}>{link.label}</a>
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </div>
  </Container>
</Section>

<style>
  .sitemap-lead {
    max-width: 60ch;
    color: var(--color-text-muted);
    margin-bottom: 2.5rem;
  }
  .sitemap-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 2.5rem 2rem;
  }
  .sitemap-group__heading {
    font-size: 1.125rem;
    margin: 0 0 0.75rem 0;
  }
  .sitemap-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .sitemap-list a {
    color: inherit;
    text-decoration: none;
  }
  .sitemap-list a:hover {
    text-decoration: underline;
  }
</style>
